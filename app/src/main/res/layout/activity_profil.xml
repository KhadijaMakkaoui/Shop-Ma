<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- 1. Fragment Header (En-tête réutilisable) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/headerFragProfil"
        android:name="com.example.shopma.fragments.HeaderFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Titre de la page -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mon Profil"
                android:textColor="@color/accentColor"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 2. Avatar de l'utilisateur (Image circulaire avec CardView) -->
            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="#E0E0E0"
                    android:contentDescription="Photo de profil" />
            </androidx.cardview.widget.CardView>

            <!-- 3. Bouton pour prendre une photo (Caméra) -->
            <Button
                android:id="@+id/btnCam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📷 Prendre / Changer la photo"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/accentColor"
                android:paddingVertical="12dp"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <!-- 4. Informations de l'utilisateur -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nom complet"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProfilNom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ahmed"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adresse e-mail"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProfilEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ahmed@shopma.ma"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnHist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📜 Historique des commandes"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00838F"
                android:paddingVertical="12dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>