<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- 1. En-tête (Header) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/headerFragCat"
        android:name="com.example.shopma.fragments.HeaderFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rechercher"
            android:textColor="@color/accentColor"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etSearchCategory"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Catégorie"
                android:paddingHorizontal="12dp"
                android:background="@android:drawable/editbox_background"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="OK"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/accentColor" />
        </LinearLayout>

        <!-- 4. Filtres rapides sous forme de pilules horizontales -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnFilterElec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="sans-serif-light"
                    android:text="electronics"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/primaryDark"
                    app:cornerRadius="20dp" />

                <Button
                    android:id="@+id/btnFilterJewel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="sans-serif-light"
                    android:text="jewelery"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/primaryDark"
                    app:cornerRadius="20dp" />

                <Button
                    android:id="@+id/btnFilterMen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="sans-serif-light"
                    android:text="men"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/primaryDark"
                    app:cornerRadius="20dp"                    />

                <Button
                    android:id="@+id/btnFilterWomen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="women"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/primaryDark"
                    app:cornerRadius="20dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tous les produits :"
            android:textColor="@color/gray"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <ListView
            android:id="@+id/lvProducts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@null"
            android:dividerHeight="0dp" />

    </LinearLayout>

</LinearLayout>