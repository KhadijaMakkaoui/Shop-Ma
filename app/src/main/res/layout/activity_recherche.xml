<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- En-tête / Header Fragment -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/headerFrag"
        android:name="com.example.shopma.fragments.HeaderFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Bandeau de titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00BCD4"
        android:padding="14dp"
        android:text="Tous les Produits"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Barre de Recherche -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchViewProduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:iconifiedByDefault="false"
        android:queryHint="Rechercher un produit par nom..." />

    <!-- Liste globale des produits -->
    <ListView
        android:id="@+id/lvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>