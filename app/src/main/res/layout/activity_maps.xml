<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- En-tête / Header Fragment -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/headerFrag"
        android:name="com.example.shopma.fragments.HeaderFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Titre "Points de retrait" -->
    <TextView
        android:id="@+id/tvTitlePoints"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accentColor"
        android:padding="16dp"
        android:text="Points de retrait"
        android:textColor="@color/cardview_light_background"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Google Maps Fragment occupant le reste de l'écran -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>