<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:background="@color/white"
    android:gravity="center_vertical">
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView android:id="@+id/tvItemPanTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="@color/black" android:maxLines="1"/>
        <TextView android:id="@+id/tvItemPanPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/primaryColor"/>
    </LinearLayout>
    <Button android:id="@+id/btnMoins" android:layout_width="40dp" android:layout_height="40dp" android:text="-" android:padding="0dp"/>
    <TextView android:id="@+id/tvQty" android:layout_width="30dp" android:layout_height="wrap_content" android:gravity="center" android:text="1" android:textColor="@color/black"/>
    <Button android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:padding="0dp"/>
    <ImageView android:id="@+id/ivDel" android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_delete" android:layout_marginStart="8dp"/>
</LinearLayout>